---
import { siteConfig } from "@/config/site";
---

<header class="border-b border-slate-800">
  <div class="container flex items-center justify-between py-5">
    <a href="/" class="font-semibold tracking-wide text-slate-100">{siteConfig.name}</a>
    <nav class="flex items-center gap-5 text-sm text-slate-300">
      <a href="/projects">Projects</a>
      <a href="/about">About</a>
      {siteConfig.enableBlog && <a href="/blog">Blog</a>}
      <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
    </nav>
  </div>
</header>
