---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
---

<BaseLayout
  title={`About | ${siteConfig.name}`}
  description="Full-stack technical lead based in Winnipeg: .NET, React, TypeScript, Azure and AWS, with experience across government, financial services, and SaaS."
>
  <section class="space-y-4">
    <h1 class="text-3xl font-bold">About</h1>
    <p class="max-w-3xl text-slate-300">
      I am a software developer and technical lead with over eight years of experience in full-stack, cloud-based web
      development. I focus on architecting scalable systems, mentoring teams, and turning complex business requirements
      into maintainable, performant code—on both new builds and long-lived legacy platforms. I have worked with clients
      across North America in financial services, government, and agribusiness. I lean heavily on .NET, React,
      TypeScript, and Azure, with substantial delivery on AWS as well.
    </p>
    <p class="max-w-3xl text-slate-300">
      I care about clear communication, pragmatic architecture, and shipping safely—whether that means security
      remediation, untangling high-blast-radius changes, or helping teams get unstuck without heroics.
    </p>
  </section>

  <section class="mt-10 grid gap-6 md:grid-cols-2">
    <article class="card">
      <h2 class="text-xl font-semibold">Core skills</h2>
      <ul class="mt-4 space-y-2 text-slate-300">
        <li><span class="font-medium text-slate-200">Languages & frameworks:</span> C# / .NET, TypeScript, React, Angular, Python, PHP/Laravel, SQL, Entity Framework</li>
        <li><span class="font-medium text-slate-200">Cloud & architecture:</span> Azure, AWS, Bicep, application design, REST APIs, distributed systems</li>
        <li><span class="font-medium text-slate-200">Delivery:</span> Technical leadership, code review, unit testing and quality gates, Agile/Scrum, CI/CD and DevOps-minded workflows</li>
        <li><span class="font-medium text-slate-200">Security & collaboration:</span> Security remediation with security partners, cross-team coordination, documentation and onboarding</li>
      </ul>
    </article>
    <article class="card">
      <h2 class="text-xl font-semibold">Contact</h2>
      <p class="mt-2 text-sm text-slate-400">Winnipeg, MB, Canada</p>
      <ul class="mt-4 space-y-2 text-slate-300">
        <li>Email: <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>GitHub: <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">{siteConfig.githubUrl}</a></li>
        <li>LinkedIn: <a href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer">{siteConfig.linkedinUrl}</a></li>
      </ul>
    </article>
  </section>

  <section class="mt-10 card">
    <h2 class="text-xl font-semibold">Experience</h2>
    <ol class="mt-4 space-y-8 text-slate-300">
      <li class="border-b border-slate-800 pb-8 last:border-b-0 last:pb-0">
        <p class="font-medium text-slate-200">Chief Technology Officer</p>
        <p class="text-sm text-slate-400">Campaign Compass · Jan 2026 – Present</p>
        <p class="mt-2 text-sm text-slate-400">
          <a href="https://campaigncompass.ca/" class="text-sky-400 hover:text-sky-300" target="_blank" rel="noreferrer">campaigncompass.ca</a>
          — SaaS for political and business campaigns.
        </p>
        <ul class="mt-3 list-inside list-disc space-y-1 text-slate-300">
          <li>Shape product vision and roadmap with technical perspective; lead teams toward the technical vision.</li>
          <li>Prioritize technical debt with engineering and leadership; improve operations through better tools and processes.</li>
          <li>Partner on security posture with the CEO and security team; support team performance and growth.</li>
        </ul>
      </li>
      <li class="border-b border-slate-800 pb-8 last:border-b-0 last:pb-0">
        <p class="font-medium text-slate-200">Senior Full Stack Developer, Senior Consultant</p>
        <p class="text-sm text-slate-400">CGI Inc. (government client) · Mar 2026 – Present</p>
        <ul class="mt-3 list-inside list-disc space-y-1 text-slate-300">
          <li>Government services platform rewrite: multi-layer self-serve portal for public access to services.</li>
          <li>High-impact changes with careful risk management; security remediations aligned with the security team.</li>
          <li>Workflow improvements and multi-team coordination; support for at-risk delivery commitments.</li>
        </ul>
      </li>
      <li class="border-b border-slate-800 pb-8 last:border-b-0 last:pb-0">
        <p class="font-medium text-slate-200">Senior Full Stack Developer, Senior Consultant</p>
        <p class="text-sm text-slate-400">Online Business Systems (now CGI Inc.) · Jan 2025 – Mar 2026 · Financial services client</p>
        <ul class="mt-3 list-inside list-disc space-y-1 text-slate-300">
          <li>Financial platform rewrite including a secure Automated Fund Transfer solution.</li>
          <li>Cross-team estimation, code review, and patterns that keep complexity under control.</li>
          <li>Established unit testing foundations; authored onboarding and technical documentation.</li>
        </ul>
      </li>
      <li class="border-b border-slate-800 pb-8 last:border-b-0 last:pb-0">
        <p class="font-medium text-slate-200">Lead Software Developer, Senior Consultant</p>
        <p class="text-sm text-slate-400">Online Business Systems (now CGI Inc.) · Jun 2021 – Jan 2025 · AMS team</p>
        <ul class="mt-3 list-inside list-disc space-y-1 text-slate-300">
          <li>Led a multi-client AMS team across .NET Core, Angular, Python, AWS, Azure, SQL, PHP, and more.</li>
          <li>RFP/RFQ support, solution architecture, and client onboarding (environments, docs, operations).</li>
          <li>Improved workflows and governance; hands-on support while growing team autonomy.</li>
        </ul>
      </li>
      <li>
        <p class="font-medium text-slate-200">Full Stack Developer, Consultant</p>
        <p class="text-sm text-slate-400">Online Business Systems (now CGI Inc.) · Dec 2017 – Jun 2021 · Internal systems</p>
        <ul class="mt-3 list-inside list-disc space-y-1 text-slate-300">
          <li>Full stack web apps: .NET APIs, SQL/MySQL, Angular and React on Azure and AWS.</li>
          <li>Amazon Connect flows, NativeScript–.NET integrations, dockerized PHP/Laravel with CI/CD, SSRS and SQL maintenance.</li>
        </ul>
      </li>
    </ol>
  </section>

  <section class="mt-10 card">
    <h2 class="text-xl font-semibold">Education</h2>
    <p class="mt-4 text-slate-300">
      <span class="font-medium text-slate-200">Bachelor of Science, Computer Science</span>
      — University of Manitoba, Winnipeg, Canada
    </p>
  </section>
</BaseLayout>
