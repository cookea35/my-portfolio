---
import { getCollection } from "astro:content";
import ProjectCard from "@/components/ProjectCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import { contentSlug } from "@/lib/contentSlug";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout title={`${siteConfig.name} | Portfolio`} description={siteConfig.description}>
  <section class="space-y-6">
    <p class="text-sm uppercase tracking-widest text-sky-300">{siteConfig.role}</p>
    <h1 class="text-4xl font-bold leading-tight sm:text-5xl">Interactive resume and project portfolio</h1>
    <p class="max-w-2xl text-lg text-slate-300">{siteConfig.description}</p>
    <div class="flex gap-4">
      <a class="rounded-lg bg-sky-400 px-4 py-2 text-slate-950 hover:bg-sky-300" href="/projects">View Projects</a>
      <a class="rounded-lg border border-slate-700 px-4 py-2 text-slate-100 hover:border-slate-500" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">GitHub Profile</a>
    </div>
  </section>

  <section class="mt-14 space-y-6">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-semibold">Featured work</h2>
      <a href="/projects" class="text-sm">Browse all projects</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          summary={project.data.summary}
          tech={project.data.tech}
          href={`/projects/${contentSlug(project.id)}`}
          githubUrl={project.data.githubUrl}
          featured={project.data.featured}
        />
      ))}
    </div>
  </section>
</BaseLayout>
