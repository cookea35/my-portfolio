---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const personalProjects = projects.filter((project) => project.data.category === "personal");
const professionalProjects = projects.filter((project) => project.data.category === "professional");
---

<BaseLayout title="Projects | Portfolio" description="Selected software projects and engineering case studies.">
  <section class="space-y-3">
    <h1 class="text-3xl font-bold">Projects</h1>
    <p class="max-w-2xl text-slate-300">
      Explore projects by category to quickly find personal builds and professional work.
    </p>
  </section>
  <section class="mt-8 grid gap-5 md:grid-cols-2">
    <a class="rounded-xl border border-slate-700 bg-slate-900/40 p-6 transition hover:border-sky-400 hover:bg-slate-900/70" href="/projects/personal">
      <p class="text-xs uppercase tracking-wide text-sky-300">Category</p>
      <h2 class="mt-2 text-2xl font-semibold">Personal Projects</h2>
      <p class="mt-3 text-slate-300">
        Side projects, experiments, and self-directed builds.
      </p>
      <p class="mt-4 text-sm text-slate-400">{personalProjects.length} project{personalProjects.length === 1 ? "" : "s"}</p>
    </a>
    <a class="rounded-xl border border-slate-700 bg-slate-900/40 p-6 transition hover:border-sky-400 hover:bg-slate-900/70" href="/projects/professional">
      <p class="text-xs uppercase tracking-wide text-sky-300">Category</p>
      <h2 class="mt-2 text-2xl font-semibold">Professional Projects</h2>
      <p class="mt-3 text-slate-300">
        Work delivered for teams, clients, or organizations.
      </p>
      <p class="mt-4 text-sm text-slate-400">{professionalProjects.length} project{professionalProjects.length === 1 ? "" : "s"}</p>
    </a>
  </section>
</BaseLayout>
