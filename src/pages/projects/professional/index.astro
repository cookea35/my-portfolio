---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { contentSlug } from "@/lib/contentSlug";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.category === "professional")
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title="Professional Projects | Portfolio" description="Professional software projects and case studies.">
  <section class="space-y-3">
    <a href="/projects" class="text-sm text-sky-300 hover:underline">← Back to all project categories</a>
    <h1 class="text-3xl font-bold">Professional Projects</h1>
    <p class="max-w-2xl text-slate-300">
      Projects built in professional contexts with cross-functional teams and production goals.
    </p>
  </section>
  <section class="mt-8 grid gap-5">
    {projects.map((project) => (
      <ProjectCard
        title={project.data.title}
        summary={project.data.summary}
        tech={project.data.tech}
        href={`/projects/${contentSlug(project.id)}`}
        githubUrl={project.data.githubUrl}
        featured={project.data.featured}
      />
    ))}
  </section>
</BaseLayout>
